# Lipwa-Trust Backend Configuration
# Copy this file to .env and update with your own values

# Database Configuration
# For SQLite (development/MVP):
DATABASE_URL="sqlite:///./lipwa_trust.db"

# For PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@localhost:5432/lipwa_trust"

# Security - CHANGE THIS IN PRODUCTION!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="3b0f51d8c2c8f6a9e14d7b2c5f6a9e14d7b2c5f6a9e14d7b2c5f6a9e14d7b2c5"

# Token Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Server Configuration
SERVER_HOST="0.0.0.0"
SERVER_PORT=8000
SERVER_RELOAD=true

# Logging Configuration
LOG_LEVEL="INFO"

# CORS Configuration (for frontend domain)
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000"

# API Documentation
OPENAPI_URL="/openapi.json"
DOCS_URL="/docs"
REDOC_URL="/redoc"
